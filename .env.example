# jarvis-suit — configuration. Copier en `.env` (jamais committé).
# En mode mock (défaut), AUCUNE de ces valeurs n'est requise.

# --- Mode global ------------------------------------------------------------
# mock = tout en données factices, aucun réseau, aucun credential (défaut).
# real = branche les backends réels quand ils sont configurés ci-dessous.
JARVIS_MODE=mock

# --- Serveur API ------------------------------------------------------------
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8000

# --- Journal ----------------------------------------------------------------
# Chemin du journal SQLite. ":memory:" pour un journal éphémère (tests).
JARVIS_DB_PATH=var/jarvis.db

# --- Inférence --------------------------------------------------------------
# Inférence LOCALE via Ollama (recommandé ici : CPU, sans build). Endpoint natif.
# JARVIS_OLLAMA_URL=http://localhost:11434
# JARVIS_LOCAL_MODEL=qwen2.5:3b
# Ou un serveur OpenAI-compatible générique (ex. OpenJarvis `jarvis serve`).
# JARVIS_INFERENCE_URL=http://localhost:8080/v1
# Cloud (extra [cloud]) : raisonnement lourd / rédaction. (Pas utilisé pour l'instant.)
# ANTHROPIC_API_KEY=
# JARVIS_CLOUD_MODEL=claude-sonnet-4-6

# --- Telegram (interface I/O) ----------------------------------------------
# Sans token => MockTelegram (aucun envoi réel).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Desktop ----------------------------------------------------------------
# mock  = MockDesktop (config 3 écrans factice) — défaut, pour la démo/tests.
# gnome = backend GNOME/Wayland réel (nécessite l'extension pour le placement).
JARVIS_DESKTOP_BACKEND=mock

# --- Night Shift (VULCAN désarmé : simulation dry-run) ----------------------
JARVIS_NIGHT_SHIFT_ENABLED=false
JARVIS_MAX_USD_NIGHT=5.0
JARVIS_MAX_TASKS_NIGHT=6

# --- Mails (HERMES) ---------------------------------------------------------
# mock  = boîte factice (défaut). gmail = API Gmail réelle (extra [google] + OAuth).
JARVIS_MAIL_BACKEND=mock
# Chemins des fichiers OAuth Google (cf. docs/MANUAL_SETUP.md).
# GMAIL_CREDENTIALS_PATH=secrets/gmail_credentials.json
# GMAIL_TOKEN_PATH=secrets/gmail_token.json
