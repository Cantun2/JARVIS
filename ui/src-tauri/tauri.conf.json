{
  "$schema": "https://schema.tauri.app/config/2",
  "//": "Packaging différé, cf docs/MANUAL_SETUP.md. webkit2gtk absent sur la machine de dev : NE PAS lancer `tauri dev/build` ici. Ce fichier scaffolde la config uniquement ; le build natif se fait sur une machine outillée.",
  "productName": "jarvis-suit",
  "version": "0.1.0",
  "identifier": "local.jarvis-suit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JARVIS · Mission Control",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
